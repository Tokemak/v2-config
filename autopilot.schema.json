{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Autopilot Configuration",
  "description": "Tokemak v2 autopilot system configuration across supported chains",
  "type": "object",
  "required": ["systems"],
  "additionalProperties": false,
  "properties": {
    "systems": {
      "type": "array",
      "description": "List of blockchain system configurations",
      "items": {
        "$ref": "#/definitions/System"
      }
    }
  },
  "definitions": {
    "EthereumAddress": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "description": "A 20-byte Ethereum address in hex format"
    },
    "System": {
      "type": "object",
      "description": "Configuration for a single blockchain system deployment",
      "required": [
        "chainName",
        "isMainnet",
        "chainId",
        "hypernativeChainName",
        "systemName",
        "systemRegistry",
        "lens",
        "liquidator",
        "subgraphPrimary",
        "deployers",
        "chainlinkKeepers",
        "publishAprs",
        "publishToDefillama",
        "serviceAccounts"
      ],
      "additionalProperties": false,
      "properties": {
        "chainName": {
          "type": "string",
          "description": "Human-readable name of the blockchain network"
        },
        "isMainnet": {
          "type": "boolean",
          "description": "Whether this is a mainnet (true) or testnet (false) deployment"
        },
        "chainId": {
          "type": "string",
          "description": "The EVM chain ID as a string",
          "pattern": "^[0-9]+$"
        },
        "systemName": {
          "type": "string",
          "description": "The system generation name",
          "enum": ["gen3"]
        },
        "hypernativeChainName": {
          "type": "string",
          "description": "The name Hypernative uses to reference a chain in a watchlist"
        },
        "systemRegistry": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Address of the SystemRegistry contract"
        },
        "lens": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Address of the Lens contract"
        },
        "liquidator": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Address of the Liquidator contract"
        },
        "liquidatorExecutor": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Address of the LiquidatorExecutor contract"
        },
        "rewarderAutoLoader": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Address of the RewarderAutoLoader contract"
        },
        "subgraphPrimary": {
          "type": "string",
          "format": "uri",
          "description": "URL of the primary subgraph GraphQL endpoint"
        },
        "deployers": {
          "type": "array",
          "description": "List of deployer addresses authorized for this chain",
          "items": {
            "$ref": "#/definitions/EthereumAddress"
          },
          "minItems": 1
        },
        "chainlinkKeepers": {
          "type": "array",
          "description": "Chainlink Automation keeper registrations for this chain",
          "items": {
            "$ref": "#/definitions/ChainlinkKeeper"
          }
        },
        "publishAprs": {
          "type": "boolean",
          "description": "Whether to publish APR data for this chain"
        },
        "publishToDefillama": {
          "type": "boolean",
          "description": "Whether to publish data to DefiLlama for this chain"
        },
        "serviceAccounts": {
          "type": "array",
          "description": "Service accounts used by autopilot operations on this chain",
          "items": {
            "$ref": "#/definitions/ServiceAccount"
          },
          "minItems": 1
        }
      }
    },
    "ChainlinkKeeper": {
      "type": "object",
      "description": "A Chainlink Automation keeper registration",
      "required": ["name", "id", "url", "deprecated"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the keeper"
        },
        "id": {
          "type": "string",
          "description": "Chainlink Automation upkeep ID",
          "pattern": "^[0-9]+$"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the Chainlink Automation dashboard for this keeper"
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this keeper registration is deprecated"
        }
      }
    },
    "ServiceAccount": {
      "type": "object",
      "description": "A service account used for automated operations",
      "required": ["name", "address", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the service account"
        },
        "address": {
          "$ref": "#/definitions/EthereumAddress",
          "description": "Ethereum address of the service account"
        },
        "type": {
          "type": "string",
          "description": "Category of the service account's function",
          "enum": [
            "pricing",
            "rewards",
            "swaps",
            "debtReporting",
            "solver",
            "stats",
            "stoke"
          ]
        }
      }
    }
  }
}
